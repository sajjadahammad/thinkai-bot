PROJECT_NAME=OliveBot
API_V1_STR=/api/v1

# Local Docker Compose database:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/olivebot

# On Render, use the database's Internal Database URL instead:
# DATABASE_URL=postgresql://USER:PASSWORD@INTERNAL_HOST:5432/DATABASE

# Configure at least one live LLM provider.
MISTRAL_API_KEY=
GEMINI_API_KEY=

# Optional. Leave empty locally and on Render to let the app infer it.
# Local default: http://127.0.0.1:8000/api/v1/logs/
# Render default: ${RENDER_EXTERNAL_URL}/api/v1/logs/
INGESTION_URL=

# Render provides PORT automatically. Use this only for local overrides.
PORT=8000

# JWT auth settings. Replace JWT_SECRET_KEY in every real environment.
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Startup admin user. The backend creates or syncs this account on boot.
ADMIN_EMAIL=admin@olivebot.ai
ADMIN_PASSWORD=change_me_admin_password
